#!/bin/bash

source "$CONFIG_DIR/colors.sh"

PLUGIN_DIR="$CONFIG_DIR/plugins"
FONT="SF Pro"
ICON_FONT="JetBrainsMono Nerd Font"
PADDING=6

##### Register custom events #####
sketchybar --add event aerospace_workspace_change

##### Bar Appearance #####
sketchybar --bar \
    position=top \
    height=37 \
    blur_radius=0 \
    color=$TRANSPARENT \
    border_width=0 \
    margin=0 \
    y_offset=0 \
    padding_left=10 \
    padding_right=10 \
    topmost=window

##### Defaults #####
sketchybar --default \
    icon.font="$ICON_FONT:Bold:15.0" \
    icon.color=$BASE \
    icon.padding_left=8 \
    icon.padding_right=4 \
    label.font="$FONT:Medium:13.0" \
    label.color=$BASE \
    label.padding_left=4 \
    label.padding_right=8 \
    background.color=$PEACH \
    background.corner_radius=10 \
    background.height=28 \
    background.padding_left=$PADDING \
    background.padding_right=$PADDING

##### Left: Workspaces #####
for i in $(seq 1 3); do
    sketchybar --add item space.$i left \
        --set space.$i \
            icon=$i \
            icon.font="$ICON_FONT:Bold:13.0" \
            icon.color=$PEACH \
            icon.padding_left=10 \
            icon.padding_right=4 \
            label.drawing=on \
            label.font="$ICON_FONT:Bold:14.0" \
            label.color=$PEACH \
            label.padding_left=0 \
            label.padding_right=8 \
            background.color=$BASE \
            background.corner_radius=8 \
            background.height=26 \
            background.drawing=off \
            click_script="aerospace workspace $i" \
            script="$PLUGIN_DIR/space.sh" \
        --subscribe space.$i aerospace_workspace_change front_app_switched space_windows_change
done

# Separator after workspaces
sketchybar --add item space_separator left \
    --set space_separator \
        icon="〉" \
        icon.font="$FONT:Light:14.0" \
        icon.color=$OVERLAY0 \
        icon.padding_left=6 \
        icon.padding_right=6 \
        label.drawing=off \
        background.drawing=off

##### Left: Front App (after workspaces, like reference image) #####
sketchybar --add item front_app left \
    --set front_app \
        icon.drawing=on \
        icon.font="sketchybar-app-font:Regular:15.0" \
        icon.color=$PEACH \
        label.font="$FONT:Semibold:13.0" \
        label.color=$TEXT \
        background.drawing=off \
        script="$PLUGIN_DIR/front_app.sh" \
    --subscribe front_app front_app_switched

##### Right: Widgets #####

# Clock (rightmost)
sketchybar --add item clock right \
    --set clock \
        icon=󰥔 \
        update_freq=30 \
        script="$PLUGIN_DIR/clock.sh"

# Battery
sketchybar --add item battery right \
    --set battery \
        update_freq=120 \
        script="$PLUGIN_DIR/battery.sh" \
    --subscribe battery system_woke power_source_change

# Wifi
sketchybar --add item wifi right \
    --set wifi \
        icon=󰖩 \
        script="$PLUGIN_DIR/wifi.sh" \
    --subscribe wifi wifi_change

# Volume
sketchybar --add item volume right \
    --set volume \
        script="$PLUGIN_DIR/volume.sh" \
    --subscribe volume volume_change

# Now Playing
sketchybar --add item media right \
    --set media \
        icon=󰎆 \
        update_freq=5 \
        script="$PLUGIN_DIR/media.sh"

##### Set initial workspace highlight #####
FOCUSED="$(aerospace list-workspaces --focused 2>/dev/null || echo 1)"
sketchybar --trigger aerospace_workspace_change FOCUSED_WORKSPACE="$FOCUSED"

##### Force update #####
sketchybar --update
