#!/bin/bash
# Restore SketchyBar and JankyBorders to Catppuccin Macchiato Peach

cat > "$HOME/.config/sketchybar/colors.sh" << 'EOF'
#!/bin/bash

# Catppuccin Macchiato
export BASE=0xff24273a
export MANTLE=0xff1e2030
export CRUST=0xff181926
export SURFACE0=0xff363a4f
export SURFACE1=0xff494d64
export SURFACE2=0xff5b6078
export TEXT=0xffcad3f5
export SUBTEXT1=0xffb8c0e0
export SUBTEXT0=0xffa5adcb
export OVERLAY0=0xff6e738d
export OVERLAY1=0xff8087a2
export PEACH=0xfff5a97f
export RED=0xffed8796
export GREEN=0xffa6da95
export BLUE=0xff8aadf4
export YELLOW=0xffeed49f
export MAUVE=0xffc6a0f6
export TEAL=0xff8bd5ca
export TRANSPARENT=0x00000000
EOF

cat > "$HOME/.bordersrc" << 'EOF'
options=(
    style=round
    width=10.0
    active_color=0xfff5a97f
    inactive_color=0xff494d64
)
borders "${options[@]}"
EOF

brew services restart sketchybar 2>/dev/null &
brew services restart borders 2>/dev/null &

# Restore Fresh theme to dracula
python3 -c "
import json, os
config_path = os.path.expanduser('~/.config/fresh/config.json')
if os.path.exists(config_path):
    with open(config_path) as f:
        config = json.load(f)
    config['theme'] = 'dracula'
    with open(config_path, 'w') as f:
        json.dump(config, f, indent=2)
"

# Restore Ghostty theme to Catppuccin Macchiato
sed -i '' 's/^theme = .*/theme = Catppuccin Macchiato/' "$HOME/.config/ghostty/config"

echo "Restored Catppuccin Macchiato Peach theme"
